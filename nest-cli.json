{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/alcodist-lab/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/alcodist-lab/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/alcodist-lab",
  "projects": {
    "alcodist-lab": {
      "type": "application",
      "root": "apps/alcodist-lab",
      "entryFile": "main",
      "sourceRoot": "apps/alcodist-lab/src",
      "compilerOptions": {
        "tsConfigPath": "apps/alcodist-lab/tsconfig.app.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "shift-service": {
      "type": "application",
      "root": "apps/shift-service",
      "entryFile": "main",
      "sourceRoot": "apps/shift-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/shift-service/tsconfig.app.json"
      }
    },
    "worker-service": {
      "type": "application",
      "root": "apps/worker-service",
      "entryFile": "main",
      "sourceRoot": "apps/worker-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-service/tsconfig.app.json"
      }
    },
    "workplace-service": {
      "type": "application",
      "root": "apps/workplace-service",
      "entryFile": "main",
      "sourceRoot": "apps/workplace-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/workplace-service/tsconfig.app.json"
      }
    }
  }
}